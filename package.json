{
  "name": "factora",
  "version": "1.1.2",
  "description": "Create consistent, type-safe data hooks for React. Handles caching, retries, and GC so you don't have to.",
  "author": "travelr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/travelr/factora.git"
  },
  "homepage": "https://github.com/travelr/factora",
  "bugs": {
    "url": "https://github.com/travelr/factora/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "typescript",
    "data-fetching",
    "api",
    "cache",
    "caching",
    "retry",
    "retries",
    "stale-while-revalidate",
    "swr",
    "garbage-collection",
    "gc",
    "singleton",
    "store",
    "factory",
    "state-management",
    "server-state",
    "zustand"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pure": {
      "import": {
        "types": "./dist/pure.d.mts",
        "default": "./dist/pure.mjs"
      },
      "require": {
        "types": "./dist/pure.d.cts",
        "default": "./dist/pure.cjs"
      }
    },
    "./adapter/axios": {
      "import": {
        "types": "./dist/adapter/axios.d.mts",
        "default": "./dist/adapter/axios.mjs"
      },
      "require": {
        "types": "./dist/adapter/axios.d.cts",
        "default": "./dist/adapter/axios.cjs"
      }
    },
    "./adapter/loglevel": {
      "import": {
        "types": "./dist/adapter/loglevel.d.mts",
        "default": "./dist/adapter/loglevel.mjs"
      },
      "require": {
        "types": "./dist/adapter/loglevel.d.cts",
        "default": "./dist/adapter/loglevel.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "coverage": "vitest run --coverage",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest --config vitest.config.ts",
    "test:artifacts": "npm run build && node scripts/verify-artifacts.mjs"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "loglevel": "^1.8.0",
    "react": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "loglevel": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.10",
    "axios": "^1.18.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "loglevel": "^1.9.2",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "19.2.7",
    "tsdown": "^0.22.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": "prettier --write",
    "*.{ts,tsx,js}": "oxlint --fix"
  }
}
