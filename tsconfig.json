{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@adapter/*": ["./src/adapter/*"],
      "@utils/*": ["./src/utils/*"],
      "@/types/*": ["./src/types/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./src",
    "declaration": true,
    "isolatedDeclarations": true,
    "declarationDir": "dist/types",
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
